# PostgreSQL - Ganti dengan connection string dari Neon/Supabase/Railway
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=5000
NODE_ENV=development

# CORS - Pisahkan dengan koma. Gunakan * untuk allow semua (tidak direkomendasikan di production)
# Contoh production: https://sapadan.vercel.app,https://sapadan-driver.vercel.app
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
